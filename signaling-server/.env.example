# signaling-server/.env
# Copy this to .env — never commit .env itself

NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5173

# Local PostgreSQL (native WSL install)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rda
DB_USER=rda_app
DB_PASSWORD=localdevpassword
DB_SSL=false

# JWT — generate a real secret with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string_before_production
JWT_EXPIRES=15m

# Google OAuth2
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI must include: http://localhost:5173
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
